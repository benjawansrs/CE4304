class Circle:
    def __init__(self, radius, color="black"):
        self.radius = radius
        self.color = color

    def area(self):
        return 3.14159 * self.radius ** 2

    def perimeter(self):
        return 2 * 3.14159 * self.radius

    def scale(self, factor):
        self.radius *= factor
